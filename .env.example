# Copy to `.env` (or set these in your hosting dashboard) before going live.
# Never commit real passwords.

# Password admins type to record results.
ADMIN_PASSWORD=change-me-admin

# Password only YOU know, to correct/delete records.
SUPERADMIN_PASSWORD=change-me-superadmin

# Optional: where the SQLite file lives (defaults to ./data).
# Point this at a persistent disk in production so data survives restarts.
# BACKYARD_DATA_DIR=/data
